# Must match a Redirect URI in the Spotify Dashboard exactly (path included).
# Default in code is http://127.0.0.1:3000/api/auth/callback — use 127.0.0.1, not localhost, unless you register localhost in the dashboard.
SPOTIFY_REDIRECT_URI=""

